# Renomeie este arquivo para .env e ajuste os valores

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=pizzaria_db
DB_PORT=3306
DB_SSL=false
# Ao usar um banco gratuito hospedado (ex: TiDB Cloud), troque DB_HOST/DB_PORT
# pelos dados fornecidos por eles e coloque DB_SSL=true

PORT=3000

# Use uma string longa e aleatória em produção
JWT_SECRET=troque_esta_chave_por_algo_seguro
